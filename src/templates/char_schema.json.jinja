{
  "type": "OBJECT",
  "description": "An OpenAPI structural JSON extraction schema targeting a complete D&D 5e character sheet payload.",
  "properties": {
    "name": { "type": "STRING" },
    "race": { "type": "STRING" },
    "level": { "type": "INTEGER" },
    "max_hp": { "type": "INTEGER" },
    "armor_class": { "type": "INTEGER" },
    "initiative_modifier": { "type": "INTEGER", "description": "Static bonuses to initiative from feats or attributes." },
    "speed": { "type": "INTEGER" },
    "passive_perception": { "type": "INTEGER" },
    "passive_investigation": { "type": "INTEGER" },
    "passive_insight": { "type": "INTEGER" },
    "gold_pieces": { "type": "NUMBER" },
    "stats": {
      "type": "OBJECT",
      "properties": {
        "strength": { "type": "INTEGER" },
        "dexterity": { "type": "INTEGER" },
        "constitution": { "type": "INTEGER" },
        "intelligence": { "type": "INTEGER" },
        "wisdom": { "type": "INTEGER" },
        "charisma": { "type": "INTEGER" }
      },
      "required": ["strength", "dexterity", "constitution", "intelligence", "wisdom", "charisma"]
    },
    "classes": {
      "type": "ARRAY",
      "description": "Array of strings showing lowercase class and level, e.g. ['rogue 3', 'fighter 2']",
      "items": { "type": "STRING" }
    },
    "total_hit_dice": {
      "type": "ARRAY",
      "description": "Total hit dice capacity expressions, e.g. ['3d8', '2d10']",
      "items": { "type": "STRING" }
    },
    "total_spell_slots": {
      "type": "OBJECT",
      "description": "Map representing slot level strings to integer limits, e.g., {'1': 4, '2': 3}",
      "properties": {
        "1": { "type": "INTEGER", "default": 0 },
        "2": { "type": "INTEGER", "default": 0 },
        "3": { "type": "INTEGER", "default": 0 },
        "4": { "type": "INTEGER", "default": 0 },
        "5": { "type": "INTEGER", "default": 0 },
        "6": { "type": "INTEGER", "default": 0 },
        "7": { "type": "INTEGER", "default": 0 },
        "8": { "type": "INTEGER", "default": 0 },
        "9": { "type": "INTEGER", "default": 0 }
      }
    },
    "proficiencies": {
      "type": "OBJECT",
      "properties": {
        "saving_throws": { "type": "ARRAY", "items": { "type": "STRING" }, "description": "Lowercase 3-letter slugs: ['str', 'dex']" },
        "skills": { "type": "ARRAY", "items": { "type": "STRING" }, "description": "Lowercase hyphenated slugs: ['athletics', 'sleight-of-hand']" },
        "expertise": { "type": "ARRAY", "items": { "type": "STRING" } },
        "weapons": { "type": "ARRAY", "items": { "type": "STRING" } },
        "armor": { "type": "ARRAY", "items": { "type": "STRING" } },
        "tools": { "type": "ARRAY", "items": { "type": "STRING" } },
        "languages": { "type": "ARRAY", "items": { "type": "STRING" } }
      }
    },
    "feats": { "type": "ARRAY", "items": { "type": "STRING" }, "description": "List of slugged feats: ['great-weapon-master']" },
    "passive_features": { "type": "ARRAY", "items": { "type": "STRING" }, "description": "Class attributes: ['cunning-action', 'action-surge']" },
    "known_spells": { "type": "ARRAY", "items": { "type": "STRING" }, "description": "List of lowercase hyphenated spell names." },
    "inventory_slugs": { "type": "ARRAY", "items": { "type": "STRING" }, "description": "Items in inventory." },
    "attuned_items": { "type": "ARRAY", "items": { "type": "STRING" } }
  },
  "required": ["name", "race", "level", "max_hp", "armor_class", "stats", "classes", "total_hit_dice", "proficiencies"]
}
